# ─────────────────────────────────────────────
# BACKEND SERVICES — A través de API Gateway
# ─────────────────────────────────────────────

# Auth Service API
NEXT_PUBLIC_AUTH_URL=http://api_gateway:8080/api/auth

# Core Service API (GraphQL and general core endpoints)
NEXT_PUBLIC_CORE_URL=http://api_gateway:8080/api/core
NEXT_PUBLIC_GRAPHQL_URL=http://api_gateway:8080/api/core/graphql

# Forum Service API
NEXT_PUBLIC_FORUM_URL=http://api_gateway:8080/api/forum

# Gamification Service API
NEXT_PUBLIC_GAME_URL=http://api_gateway:8080/api/game

# ─────────────────────────────────────────────
# AUTH0 — Credenciales de tu tenant
# ─────────────────────────────────────────────

# Secreto aleatorio de al menos 32 caracteres. Genera uno con:
#   openssl rand -hex 32
AUTH0_SECRET=

# Dominio del tenant Auth0 (solo el hostname, sin https://)
AUTH0_DOMAIN=

# URL base de tu app (sin trailing slash)
APP_BASE_URL=http://localhost:3000

# Credenciales de la aplicacion Auth0 (tipo "Regular Web Application")
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Auth0 API Audience — necesario para que Auth0 emita un access token válido
NEXT_PUBLIC_AUTH0_AUDIENCE=https://parla.com

# ─────────────────────────────────────────────
# TRANSLATION API — MyMemory (opcional)
# ─────────────────────────────────────────────

# Email para MyMemory API (aumenta el límite de 5,000 a 50,000 caracteres/día)
NEXT_PUBLIC_MYMEMORY_EMAIL=tu-email@example.com
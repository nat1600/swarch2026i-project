# ─────────────────────────────────────────────
# AUTH0 — Credenciales de tu tenant
# Dashboard: https://manage.auth0.com
# ─────────────────────────────────────────────

# Secreto aleatorio de al menos 32 caracteres. Genera uno con:
#   openssl rand -hex 32
AUTH0_SECRET=

# Dominio del tenant Auth0 (solo el hostname, sin https://)
AUTH0_DOMAIN=

# URL base de tu app (sin trailing slash)
APP_BASE_URL=http://localhost:3000

# Credenciales de la aplicacion Auth0 (tipo "Regular Web Application")
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ─────────────────────────────────────────────
# GRAPHQL API — Backend (aun no disponible)
# ─────────────────────────────────────────────

# URL del endpoint GraphQL (visible en el cliente)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

#URL del endpoint REST del foro (visible en el cliente, prefijo NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8003

# URL del endpoint REST del core-service (phrases, flashcards, translations)
NEXT_PUBLIC_CORE_API_URL=http://localhost:8000

# ─────────────────────────────────────────────
# TRANSLATION API — MyMemory (opcional)
# ─────────────────────────────────────────────

# Email para MyMemory API (aumenta el límite de 5,000 a 50,000 caracteres/día)
NEXT_PUBLIC_MYMEMORY_EMAIL=tu-email@example.com
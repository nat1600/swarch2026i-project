# ───────────────────────────────────── RabbitMQ ─────────────────────────────────────
RABBITMQ_URL="RabbitMQ connection string used by the enrichment service. e.g. amqp://guest:guest@localhost:5672/"
QUEUE_NAME="RabbitMQ queue where enrichment requests are consumed. e.g. enrichment_queue"

# ────────────────────────────────────── MongoDB ──────────────────────────────────────
MONGO_URL="MongoDB connection string. e.g. mongodb://localhost:27017"
MONGO_DB="Name of the MongoDB database used to store enriched phrases. e.g. enrichment_db"
MONGO_COLLECTION="MongoDB collection where generated exercises are stored. e.g. enriched_phrases"

# ───────────────────────────────────── Anthropic API ─────────────────────────────────────
ANTHROPIC_API_KEY="Anthropic Claude API key used to generate contextual sentences and distractors"

# ─────────────────────────────────────── spaCy ───────────────────────────────────────
SPACY_MODEL="spaCy language model used for NLP preprocessing. e.g. en_core_web_sm"
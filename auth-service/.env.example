# ─────────────────────────────────────── Database ──────────────────────────────────────
POSTGRES_DB="Name of the PostgreSQL database. e.g. auth_db"
POSTGRES_USER="# PostgreSQL role used by the service to connect. e.g. auth_user"
POSTGRES_HOST="# Hostname or IP where PostgreSQL is running (use 'auth_database' when in Docker)"
POSTGRES_PASSWORD="Password for the PostgreSQL role above. e.g. password"
POSTGRES_PORT="Port PostgreSQL listens on. e.g. 5432"

# ───────────────────────────────────────── Auth0 ───────────────────────────────────────
AUTH0_DOMAIN="your Auth0 tenant domain. e.g. something.us.auth0.com"
AUTH0_API_AUDIENCE="Identifier for your API in Auth0. e.g. https://something.com"

# ───────────────────────────────────────── API ─────────────────────────────────────────
DEBUG="Set to true to enable the interactive docs at /docs (disable in production)"
CORDS_ORIGINS="List of strings separated by comma of the allowed origins for CORS"

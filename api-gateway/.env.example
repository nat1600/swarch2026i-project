# ─────────────────────────────────────────────────────────────────────────────
# API GATEWAY CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# This file contains all the environment variables required to run the API Gateway.
# Copy this file to .env and fill in your values.

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND SERVICES — URLs de los microservicios
# ─────────────────────────────────────────────────────────────────────────────

# Auth Service URL (puerto 8000 por defecto)
SERVICES_AUTH_URL=http://auth-service:8000

# Core Service URL (puerto 8000 por defecto) - GraphQL y core endpoints
SERVICES_CORE_URL=http://core-service:8000

# Forum Service URL (puerto 8003 por defecto)
SERVICES_FORUM_URL=http://forum-service:8003

# Gamification Service URL (puerto 8002 por defecto)
SERVICES_GAME_URL=http://gamification-service:8002

# ─────────────────────────────────────────────────────────────────────────────
# AUTH0 JWT VALIDATION — Configuración para validar tokens de Auth0
# ─────────────────────────────────────────────────────────────────────────────

# Auth0 Domain (solo el hostname, sin https://)
# Obtén este valor en: https://manage.auth0.com → Applications → Settings
auth0.domain=dev-pzxsxsfqc2je00n4.us.auth0.com

# Auth0 API Audience — debe coincidir con el audience configurado en los cliente
# Obtén este valor en: https://manage.auth0.com → APIs → Settings
auth0.audience=https://parla.com
